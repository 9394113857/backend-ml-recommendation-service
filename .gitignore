# ============================================================
# PYTHON BYTECODE & CACHE (CRITICAL)
# ============================================================
__pycache__/
*.pyc
*.pyo
*.pyd
*.py[cod]

# ============================================================
# VIRTUAL ENVIRONMENTS & ENV FILES
# ============================================================
venv/
.venv/
venv_old/
.env
.env.*
*.env

# ============================================================
# DATABASE FILES (LOCAL ONLY)
# ============================================================
*.db
*.sqlite3

# ============================================================
# LOG FILES
# ============================================================
logs/
*.log
*.gz

# ============================================================
# FLASK MIGRATIONS
# (Keep migration scripts, ignore cache)
# ============================================================
migrations/versions/__pycache__/
migrations/versions/*.pyc

# ============================================================
# TESTING / COVERAGE
# ============================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
pytestdebug.log
junit.xml
coverage.xml

# ============================================================
# OS / EDITOR FILES
# ============================================================
Thumbs.db
.DS_Store

# VS Code
.vscode/
*.code-workspace

# PyCharm / JetBrains
.idea/

# ============================================================
# TEMP / BACKUP FILES
# ============================================================
*.tmp
*.bak
*.swp

# ============================================================
# FLASK INSTANCE FOLDER (IMPORTANT)
# ============================================================
instance/